{
  "include": ["src/**/*"],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "types",
    "declarationMap": false,
    "esModuleInterop": true,
    "target": "es6",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noImplicitAny": false
  }
}
